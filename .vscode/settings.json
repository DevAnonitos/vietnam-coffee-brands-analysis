{
  // editor configs
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.defaultFormatter": "ms-python.black-formatter",
  "editor.insertSpaces": true,
  "editor.formatOnType": false,
  "editor.formatOnPaste": true,
  "editor.suggest.preview": true,
  "editor.suggest.showSnippets": true,
  "editor.inlineSuggest.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.renderWhitespace": "boundary",
  "editor.bracketPairColorization.enabled": true,
  "editor.quickSuggestions": { "strings": true },
  "editor.cursorSmoothCaretAnimation": "on",
  "files.insertFinalNewline": true,
  "editor.detectIndentation": false,
  "files.trimTrailingWhitespace": true,
  // formating & linting configs
  "isort.check": true,
  "isort.args": ["--profile", "black"],
  "ruff.enable": true,
  "ruff.lineLength": 88,
  "ruff.lint.select": ["C", "E", "F", "W"],
  // python configs
  "[python]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "python.poetryPath": "poetry",
  "python.experiments.enabled": true,
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.terminal.activateEnvironment": true,
  "python.activeStateToolPath": "state",
  "python.testing.pytestArgs": ["tests"],
  "python.experiments.optOutFrom": ["All"],
  "python.envFile": "${workspaceFolder}/.env",
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  // jupiter & notebook configs
  "jupyter.widgetScriptSources": [],
  "jupyter.logging.level": "debug",
  "jupyter.askForKernelRestart": false,
  "jupyter.themeMatplotlibPlots": true,
  "jupyter.exportWithOutputEnabled": true,
  "jupyter.interactiveWindow.notebookRepl": false,
  "jupyter.interactiveWindow.viewColumn": "active",
  "jupyter.interactiveWindow.creationMode": "multiple",
  "jupyter.interactiveWindow.cellMarker.default": "# %%",
  "jupyter.variableExplorerExclude": "module;function;builtin_function_or_method;ABCMeta;type;ModelMetaclass",
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "right"
  },
  "notebook.displayOrder": [
    "text/html",
    "image/png",
    "text/plain",
    "text/markdown",
    "application/json",
    "application/vnd.plotly.v1+json"
  ],
  "notebook.lineNumbers": "on",
  "notebook.output.scrolling": true,
  "notebook.formatOnSave.enabled": true,
  "notebook.stickyScroll.enabled": true,
  "notebook.consolidatedRunButton": true,
  "notebook.cellToolbarVisibility": "hover",
  "notebook.output.fontFamily": "JetBrains Mono, Consolas, monospace",
  // csv configs
  "csv-edit.pasteMode": "normal",
  "csv-edit.enableWrapping": true,
  "csv-edit.columnNamesStartIndex": 1,
  "csv-edit.autoColumnWidthsIgnoreComments": true,
  "csv-edit.fontFamilyInTable": "sameAsCodeEditor",
  "csv-edit.insertColBehavior": "keepRowKeepColumn",
  "csv-edit.showColumnHeaderNamesWithLettersLikeExcel": true,
  "[csv]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "janisdd.vscode-edit-csv"
  },
  // terminal configs
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.scrollback": 5000,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.defaultProfile.linux": "bash",
  // explorer & workbench configs
  "explorer.autoReveal": true,
  "explorer.compactFolders": false,
  "search.followSymlinks": false,
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook",
    "*.md": "vscode.markdown.preview.editor"
  },
  "workbench.tree.indent": 12,
  "workbench.statusBar.visible": true,
  "workbench.sideBar.location": "left",
  "workbench.editor.tabSizing": "shrink",
  "workbench.layoutControl.enabled": true,
  "workbench.panel.defaultLocation": "bottom",
  "workbench.colorTheme": "Default Dark Modern",
  "breadcrumbs.enabled": true,
  "window.commandCenter": true,
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // github confis
  "git.autofetch": "all",
  "git.autoRepositoryDetection": "openEditors",
}
