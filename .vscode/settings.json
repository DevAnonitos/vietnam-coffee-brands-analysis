{
  // editor configs
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.minimap.scale": 1,
  "editor.insertSpaces": true,
  "editor.formatOnType": false,
  "editor.linkedEditing": true,
  "editor.formatOnPaste": true,
  "editor.fontLigatures": true,
  "editor.stickyTabStops": true,
  "editor.colorDecorators": true,
  "editor.suggest.preview": true,
  "editor.smoothScrolling": true,
  "editor.cursorBlinking": "smooth",
  "editor.detectIndentation": false,
  "editor.selectionHighlight": true,
  "editor.guides.indentation": true,
  "editor.suggest.showSnippets": true,
  "editor.inlineSuggest.enabled": true,
  "editor.scrollBeyondLastLine": false,
  "editor.largeFileOptimizations": true,
  "editor.renderWhitespace": "boundary",
  "editor.accessibilitySupport": "auto",
  "editor.acceptSuggestionOnEnter": "on",
  "editor.guides.bracketPairs": "active",
  "editor.renderControlCharacters": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.suggest.shareSuggestSelections": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.defaultFormatter": "ms-python.black-formatter",
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace",
  "editor.unicodeHighlight.allowedCharacters": {
    "·": true,
    "→": true
  },
  // files configs
  "files.associations": {
    "*.ipynb": "jupyter-notebook",
    "*.yaml": "yaml",
    "*.yml": "yaml",
    "*.json": "json"
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.ipynb_checkpoints": true
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  // formating & linting configs
  "isort.check": true,
  "isort.args": ["--profile", "black"],
  "ruff.enable": true,
  "ruff.lineLength": 88,
  "ruff.lint.select": ["C", "E", "F", "W"],
  // python configs
  "[python]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "python.poetryPath": "poetry",
  "python.experiments.enabled": true,
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.terminal.activateEnvironment": true,
  "python.activeStateToolPath": "state",
  "python.testing.pytestArgs": ["tests"],
  "python.experiments.optOutFrom": ["All"],
  "python.envFile": "${workspaceFolder}/.env",
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  // jupiter & notebook configs
  "jupyter.widgetScriptSources": [],
  "jupyter.logging.level": "debug",
  "jupyter.askForKernelRestart": false,
  "jupyter.themeMatplotlibPlots": true,
  "jupyter.exportWithOutputEnabled": true,
  "jupyter.interactiveWindow.notebookRepl": false,
  "jupyter.interactiveWindow.viewColumn": "active",
  "jupyter.interactiveWindow.creationMode": "multiple",
  "jupyter.interactiveWindow.cellMarker.default": "# %%",
  "jupyter.variableExplorerExclude": "module;function;builtin_function_or_method;ABCMeta;type;ModelMetaclass",
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "right"
  },
  "notebook.displayOrder": [
    "text/html",
    "image/png",
    "text/plain",
    "text/markdown",
    "application/json",
    "application/vnd.plotly.v1+json"
  ],
  "notebook.lineNumbers": "on",
  "notebook.output.scrolling": true,
  "notebook.formatOnSave.enabled": true,
  "notebook.stickyScroll.enabled": true,
  "notebook.consolidatedRunButton": true,
  "notebook.cellToolbarVisibility": "hover",
  "notebook.consolidatedOutputButton": true,
  "notebook.output.fontFamily": "JetBrains Mono, Consolas, monospace",
  // csv configs
  "csv-edit.pasteMode": "normal",
  "csv-edit.enableWrapping": true,
  "csv-edit.columnNamesStartIndex": 1,
  "csv-edit.autoColumnWidthsIgnoreComments": true,
  "csv-edit.fontFamilyInTable": "sameAsCodeEditor",
  "csv-edit.insertColBehavior": "keepRowKeepColumn",
  "csv-edit.showColumnHeaderNamesWithLettersLikeExcel": true,
  "[csv]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "janisdd.vscode-edit-csv"
  },
  // markdown configs
  "markdown.preview.scrollEditorWithPreview": true,
  "markdown.preview.scrollPreviewWithEditor": true,
  // debug configs
  "debug.inlineValues": "auto",
  "debug.console.wordWrap": true,
  "debug.openDebug": "neverOpen",
  "debug.console.closeOnEnd": true,
  "debug.toolBarLocation": "docked",
  "debug.allowBreakpointsEverywhere": true,
  // terminal configs
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.env.linux": {},
  "terminal.integrated.scrollback": 20000,
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.enablePersistentSessions": true,
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.accessibleViewFocusOnCommandExecution": true,
  // explorer & workbench configs
  "explorer.autoReveal": true,
  "search.followSymlinks": false,
  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook",
    "*.md": "vscode.markdown.preview.editor",
  },
  "workbench.tree.indent": 20,
  "workbench.statusBar.visible": true,
  "workbench.sideBar.location": "left",
  "workbench.editor.tabSizing": "shrink",
  "workbench.layoutControl.enabled": true,
  "workbench.editor.enablePreview": false,
  "workbench.panel.defaultLocation": "bottom",
  "workbench.colorTheme": "Default Dark Modern",
  "breadcrumbs.enabled": true,
  "window.commandCenter": true,
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // search configs
  "search.mode": "view",
  "search.showLineNumbers": true,
  "search.actionsPosition": "auto",
  "search.defaultViewMode": "tree",
  "search.decorations.colors": true,
  "search.quickOpen.includeSymbols": false,
  "search.collapseResults": "alwaysCollapse",
  "search.searchEditor.focusResultsOnSearch": true,
  "search.searchEditor.doubleClickBehaviour": "goToLocation",
  // github confis
  "git.autofetch": "all",
  "git.countBadge": "all",
  "git.enableSmartCommit": true,
  "git.postCommitCommand": "sync",
  "git.autoRepositoryDetection": "openEditors",
  // AI configs
  "chat.commandCenter.enabled": true,
  // outline configs
  "breadcrumbs.enabled": true,
  "outline.showClasses": true,
  "outline.showVariables": true,
  "outline.showFunctions": true,
  "problems.showCurrentInStatus": true,
  "outline.collapseItems": "alwaysExpand",
}
